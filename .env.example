APP_NAME="The One Fact"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

# --- The One Fact ----------------------------------------------------------
# Which laravel/ai provider to use: openai, anthropic, gemini, mistral,
# groq, xai, deepseek, ollama, ... Leave empty to default to openai.
AI_PROVIDER=openai
# Optional model override. Leave empty to use the provider's default model.
AI_MODEL=
# Set the API key matching your provider:
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# For self-hosted Ollama:
# OLLAMA_URL=http://localhost:11434

# Tolkien Gateway is behind Cloudflare's JS challenge, so requests are routed
# through a FlareSolverr (headless Chrome) sidecar. See docker-compose.yml.
FLARESOLVERR_URL=http://flaresolverr:8191/v1
# FACT_SOURCE_URL=https://tolkiengateway.net/wiki/Special:Random
# FACT_REQUEST_TIMEOUT=90

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
